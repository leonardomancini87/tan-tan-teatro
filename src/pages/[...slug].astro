---
import { getCollection, type CollectionEntry } from "astro:content";
import Home from "../templates/Home.astro";
import Page from "../templates/Page.astro";
import Contact from "../templates/Contact.astro";
import List from "../templates/List.astro";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  const newsEntries = await getCollection("news");
  const workEntries = await getCollection("work");
  const soldEntries = await getCollection("sold");

  type SortableEntry = CollectionEntry<"news" | "work" | "sold">;

  const sortDate = (a: SortableEntry, b: SortableEntry) =>
    new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();

  const sortedNews = [...newsEntries].sort(sortDate);
  const sortedWork = [...workEntries].sort(sortDate);
  const sortedSold = [...soldEntries].sort(sortDate);

  const paths = pages.map((entry) => {
    const locale = entry.data.locale ?? "it";

    let items: SortableEntry[] = [];
    let baseSlug = "";

    if (entry.data.templateKey === "news-page") {
      items = sortedNews.filter((item) => (item.data.locale ?? "it") === locale);
      baseSlug = locale === "en" ? "en/news" : "appuntamenti";
    } else if (entry.data.templateKey === "work-page") {
      items = sortedWork.filter((item) => (item.data.locale ?? "it") === locale);
      baseSlug = locale === "en" ? "spettacoli/en" : "spettacoli";
    } else if (entry.data.templateKey === "exhibitions-page") {
      items = sortedSold.filter((item) => (item.data.locale ?? "it") === locale);
      baseSlug = locale === "en" ? "sold/en" : "sold";
    }

    let slugParam: string | undefined;

    const isItalianHome = entry.slug === "index" && locale === "it";
    const isEnglishHome =
      entry.data.templateKey === "index-page" &&
      locale === "en" &&
      entry.data.translationKey === "home-page";

    const isItalianNews = entry.slug === "appuntamenti" && locale === "it";
    const isEnglishNews = entry.slug === "news-en" && locale === "en";

    if (isItalianHome) {
      slugParam = undefined;
    } else if (isEnglishHome) {
      slugParam = "en";
    } else if (isItalianNews) {
      slugParam = "appuntamenti";
    } else if (isEnglishNews) {
      slugParam = "en/news";
    } else {
      slugParam = locale === "en" ? `en/${entry.slug}` : entry.slug;
    }

    return {
      params: { slug: slugParam },
      props: { entry, items, baseSlug },
    };
  });

  return paths;
}

const { entry, items, baseSlug } = Astro.props;
const templateKey = entry.data.templateKey;
---

{
  templateKey === "index-page" ? (
    <Home entry={entry} />
  ) : templateKey === "contact-page" ? (
    <Contact entry={entry} />
  ) : templateKey === "news-page" ||
    templateKey === "work-page" ||
    templateKey === "exhibitions-page" ? (
    <List entry={entry} items={items} baseSlug={baseSlug} />
  ) : (
    <Page entry={entry} />
  )
}