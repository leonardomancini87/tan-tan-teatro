---
import { getCollection } from 'astro:content';
import Home from '../templates/Home.astro';

const allPages = await getCollection('pages');

const entry = allPages.find(
  (p) => p.slug === 'index' && (p.data.locale ?? 'it') === 'it'
);

if (!entry) {
  throw new Error('Italian homepage entry not found.');
}
---

<Home entry={entry} />