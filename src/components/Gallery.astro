---
import "@fancyapps/ui/dist/fancybox/fancybox.css";

export interface GalleryItem {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  items: GalleryItem[];
  group?: string;
  title?: string;
}

const { items, group = "gallery", title } = Astro.props;
---

{title && <h3 class="gallery-title">{title}</h3>}

<div class="gallery-grid">
  {items.map((item, index) => (
    <a
      href={item.src}
      data-fancybox={group}
      data-caption={item.caption ?? item.alt}
      class={`gallery-item ${index % 5 === 0 ? "gallery-item--large" : ""}`}
      aria-label={item.alt}
    >
      <img src={item.src} alt={item.alt} loading="lazy" />
    </a>
  ))}
</div>

<script>
  import { Fancybox } from "@fancyapps/ui";

  Fancybox.bind("[data-fancybox]", {
    Thumbs: false,
    Toolbar: {
      display: {
        left: [],
        middle: [],
        right: ["zoom", "slideshow", "fullscreen", "close"],
      },
    },
  });
</script>

<style>
  .gallery-title {
    margin: 3rem 0 1.25rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1rem;
    margin: 0 0 3rem;
  }

  .gallery-item {
    position: relative;
    grid-column: span 6;
    display: block;
    overflow: hidden;
    border-radius: 10px;
    text-decoration: none;
    background: #e9e9e9;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .gallery-item--large {
    grid-column: span 12;
  }

  .gallery-item img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.45s ease, filter 0.45s ease;
  }

  .gallery-item--large img {
    aspect-ratio: 16 / 9;
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: end;
    justify-content: start;
    padding: 1rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0));
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .gallery-label {
    display: inline-block;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 999px;
    color: white;
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    backdrop-filter: blur(6px);
    background: rgba(255, 255, 255, 0.08);
  }

  .gallery-item:hover img {
    transform: scale(1.03);
    filter: brightness(0.96);
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .gallery-item,
    .gallery-item--large {
      grid-column: span 12;
    }

    .gallery-item img,
    .gallery-item--large img {
      aspect-ratio: 4 / 3;
    }
  }
</style>