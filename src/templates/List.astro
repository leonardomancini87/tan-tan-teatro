---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'pages'>;
  items?: any[];
  baseSlug?: string;
}

const { entry, items = [], baseSlug } = Astro.props;
const { Content } = await entry.render();

const { title, description, templateKey } = entry.data;
const currentLocale = entry.data.locale ?? 'it';

const showCards = templateKey !== 'news-page';

let postCounter = 0;
---

<Layout title={title} description={description} locale={currentLocale}>
  {description && (
    <header class="page-head">
      <h2 class="page-head-title">
        {description}
      </h2>
    </header>
  )}

  <section class="post-content page-template">
    <div class="post-content-body">
      <Content />
    </div>
  </section>

  {showCards && (
    <div class="post-feed">
      {items.map((post) => {
        postCounter++;
        return (
          <PostCard
            count={postCounter}
            post={post}
            slug={baseSlug ? `${baseSlug}/${post.slug}` : post.slug}
          />
        );
      })}
    </div>
  )}
</Layout>